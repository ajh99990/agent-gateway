{
  "name": "@agent-gateway/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Host-side event gateway for WeFlow -> LangGraph agent runtime.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "checkin:smoke": "tsx src/plugins/checkin/scripts/smoke.ts",
    "expedition:smoke": "tsx src/plugins/expedition/scripts/smoke.ts",
    "expedition:repair-names": "tsx src/plugins/expedition/scripts/repair-names.ts",
    "import:history": "tsx src/scripts/import-history.ts",
    "import:persona-seed": "tsx src/scripts/import-persona-seed.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "bullmq": "^5.76.5",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.8.1",
    "pg": "^8.20.0",
    "pino": "^9.12.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1"
}
