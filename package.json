{
  "name": "agent-gateway-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "init:env": "tsx scripts/init-env.ts",
    "build": "pnpm -r build",
    "gateway:build": "pnpm --filter @agent-gateway/gateway build",
    "gateway:dev": "pnpm --filter @agent-gateway/gateway dev",
    "gateway:start": "pnpm --filter @agent-gateway/gateway start",
    "gateway:import:history": "pnpm --filter @agent-gateway/gateway import:history",
    "gateway:import:persona-seed": "pnpm --filter @agent-gateway/gateway import:persona-seed",
    "web:build": "pnpm --filter @agent-gateway/web build",
    "web:dev": "pnpm --filter @agent-gateway/web dev",
    "web:start": "pnpm --filter @agent-gateway/web start",
    "web:hash-password": "pnpm --filter @agent-gateway/web hash-password"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  }
}
