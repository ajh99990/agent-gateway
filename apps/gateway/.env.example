NODE_ENV=development
LOG_LEVEL=info

# 如果要接收局域网内机器人服务端回调，请改成 0.0.0.0。
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3400
ENABLE_HEALTH_SERVER=true
GATEWAY_ADMIN_TOKEN=

REDIS_URL=redis://127.0.0.1:6479
REDIS_KEY_PREFIX=wx:event-gateway
SSE_DEDUPE_TTL_SECONDS=3600
RUN_LOCK_TTL_SECONDS=120

DATABASE_URL=postgres://agent_gateway:agent_gateway@127.0.0.1:5432/agent_gateway

# 可选：weflow / wechat-http。wechat-http 用于接收微信机器人服务端 HTTP 回调。
MESSAGE_SOURCE=weflow
# 可选：log / wechat-admin。wechat-admin 通过后台后端转发到对应机器人。
MESSAGE_SENDER=log
# 可选：agent / drop。drop 表示插件未处理的消息直接结束，不进入 quiet window / agent-runtime / Graphiti。
UNHANDLED_MESSAGE_POLICY=agent

WEFLOW_BASE_URL=http://127.0.0.1:5031
WEFLOW_ACCESS_TOKEN=replace-me
WEFLOW_SSE_PATH=/api/v1/push/messages
WEFLOW_MESSAGES_PATH=/api/v1/messages
WEFLOW_FETCH_LIMIT=80
WEFLOW_CATCHUP_FETCH_LIMIT=300
WEFLOW_TIMEOUT_MS=15000

WECHAT_ROBOT_WXID=
# 机器人服务端直连回调通常无法携带自定义 token；局域网首次联调可先留空。
WECHAT_CALLBACK_TOKEN=
WECHAT_HTTP_HISTORY_LIMIT=300
# 机器人服务端启动/重连可能推送历史消息；早于网关启动太久的消息只入库，不触发插件/agent。
WECHAT_HTTP_REALTIME_LOOKBACK_MS=30000

# 微信机器人后台地址：用于发送消息，也用于查询群成员展示名。
WECHAT_ADMIN_BASE_URL=https://192.168.50.230:8443
WECHAT_ADMIN_API_TOKEN=
WECHAT_ADMIN_ROBOT_ID=
WECHAT_ADMIN_SEND_TIMEOUT_MS=10000
WECHAT_ADMIN_SEND_MIN_INTERVAL_MS=1000
# 局域网自签证书联调时可设为 false。
WECHAT_ADMIN_TLS_REJECT_UNAUTHORIZED=true

GROUP_ONLY=true
QUIET_WINDOW_MS=8000
MENTION_QUIET_WINDOW_MS=2000
ERROR_RETRY_DELAY_MS=3000
AGENT_CONTEXT_LIMIT=30
AGENT_CONTEXT_CHAR_LIMIT=600

BOT_NAME=bot
BOT_ALIASES=bot,机器人
BOT_WECHAT_IDS=
PLUGIN_ADMIN_WECHAT_IDS=

SCHEDULER_QUEUE_NAME=gateway-scheduler
SCHEDULER_WORKER_CONCURRENCY=4
SCHEDULER_DEFAULT_TIMEZONE=Asia/Shanghai

AGENT_RUNTIME_URL=http://127.0.0.1:8080/api/agent-runs
AGENT_RUNTIME_BEARER_TOKEN=
AGENT_RUNTIME_TIMEOUT_MS=30000

GRAPHITI_MCP_URL=http://127.0.0.1:8000/mcp/
GRAPHITI_TIMEOUT_MS=5000
GRAPHITI_GROUP_PREFIX=wechat:
